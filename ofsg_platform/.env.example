# ================================================================
# OFSG Platform - Environment Variables Template
# ================================================================
# COPY THIS FILE to .env and fill in YOUR values
# Example: cp .env.example .env
# ================================================================

# ===== DJANGO SETTINGS =====
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ===== DATABASE CONFIGURATION =====
# For LOCAL DEVELOPMENT (SQLite - no setup needed):
# Leave DATABASE_URL blank (commented out)

# For PRODUCTION (PostgreSQL):
# Replace with your actual PostgreSQL connection string from Render/Railway/ElephantSQL
# Format: postgresql://username:password@hostname:5432/database_name
# Example: postgresql://user123:pass456@db.example.com:5432/ofsg_db
# DATABASE_URL=postgresql://username:password@hostname:5432/database_name

# Optional: Database connection pool settings
DB_CONN_MAX_AGE=600
DB_SCHEMA=

# ===== EMAIL CONFIGURATION (SendGrid) =====
# Get API key from: https://app.sendgrid.com/settings/api_keys
EMAIL_BACKEND=sendgrid_backend.SendgridBackend
SENDGRID_API_KEY=your-sendgrid-api-key-here
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ===== AWS S3 CONFIGURATION (File Storage) =====
# For member document uploads (passport photos, ID documents)
# Leave blank to store files locally on server
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# ===== RENDER DEPLOYMENT (Auto-filled by Render) =====
RENDER_EXTERNAL_HOSTNAME=

# ===== SECURITY =====
# Set to True only in development
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ===== PASSWORD VALIDATION =====
PASSWORD_MIN_LENGTH=10

# ===== SENTRY (Error Tracking - Optional) =====
# SENTRY_DSN=https://your-sentry-key@sentry.io/your-project-id

# ===== OTHER =====
# Add any other environment-specific settings here
